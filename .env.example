# Salesforce Environment Variables
# Copy this file to .env and fill in your actual credentials

# Salesforce Login URL (from sfdx-project.json)
SF_LOGIN_URL=https://softcode-dev-ed.develop.my.salesforce.com/

# Salesforce User Credentials
SF_USERNAME=your-username@example.com
SF_PASSWORD=your-password
SF_SECURITY_TOKEN=your-security-token

# Optional: Org ID for API calls
# SF_ORG_ID=your-org-id

# Playwright Configuration
PLAYWRIGHT_TEST_TIMEOUT=60000
PLAYWRIGHT_EXPECT_TIMEOUT=10000

# CI/CD Environment
# CI=false