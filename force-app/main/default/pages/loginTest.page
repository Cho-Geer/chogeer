<apex:page
  showHeader="false"
  applyHtmlTag="false"
  standardStylesheets="false"
  controller="LoginTestCtrl"
  cache="false"
  docType="html-5.0"
>
  <!-- Begin Default Content REMOVE THIS -->
  <apex:form id="loginForm">
    <apex:pageBlock id="block">
      <apex:pageMessages />
      <apex:pageBlockButtons
        location="top"
        style="display: flex; flex-direction: row-reverse"
      >
        <apex:commandButton
          value="OK"
          onclick="
            callCtrl();
            return false;
          "
        />
      </apex:pageBlockButtons>
      <apex:pageBlockSection
        id="blockSection"
        title="My Content Section"
        columns="2"
      >
        <apex:outputLabel
          value="FirstName: "
          for="firstName"
        ></apex:outputLabel>
        <apex:inputText value="{!firstName}" id="firstName" />

        <apex:outputLabel value="LastName: " for="lastName"></apex:outputLabel>
        <apex:inputText value="{!lastName}" id="lastName" />

        <apex:outputLabel value="email: " for="email"></apex:outputLabel>
        <apex:inputText value="{!email}" id="email" />
      </apex:pageBlockSection>
    </apex:pageBlock>
  </apex:form>
  <!-- End Default Content REMOVE THIS -->
  <script type="text/javascript">
    function callCtrl() {
      var firstName = document.getElementById(
        "{!$Component.loginForm.block.blockSection.firstName}"
      ).value;
      var lastName = document.getElementById(
        "{!$Component.loginForm.block.blockSection.lastName}"
      ).value;
      var email = document.getElementById(
        "{!$Component.loginForm.block.blockSection.email}"
      ).value;
      Visualforce.remoting.Manager.invokeAction(
        "{!$RemoteAction.LoginTestCtrl.registerUser}",
        firstName,
        lastName,
        email,
        function (result, event) {
          console.log("event status :", event.status);
          if (event.status) {
            var account = result;
            console.log("Response is : " + JSON.stringify(result));
            // console.log('Account Name is : ' + account.Name);
            // console.log('Account Owner Name is : ' + account.Owner.Name);
          } else {
            alert(event.message);
          }
        },
        { escape: true }
      );
    }
  </script>
</apex:page>
